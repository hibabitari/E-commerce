{% extends 'base.html.twig' %}
{% block title %}Login{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-4">
        <h2 class="mb-4">Connexion</h2>
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}
        <form method="post">
            <div class="mb-3">
                <label>Email</label>
                <input type="email" name="_username" class="form-control" value="{{ last_username }}" required>
            </div>
            <div class="mb-3">
                <label>Mot de passe</label>
                <input type="password" name="_password" class="form-control" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-primary w-100">Se connecter</button>
        </form>
        <a href="{{ path('app_register') }}" class="d-block mt-3 text-center">Pas encore inscrit ?</a>
    </div>
</div>
{% endblock %}
